{
    "agent": "triage-agent",
    "model": "haiku",
    "max_turns": 10,
    "filesystem": {
        "read": ["memory/tickets/*/triage.json", "memory/framework-catalog.md"],
        "write": ["memory/tickets/*/triage.json", "memory/tickets/*/checkpoint.json", "memory/tickets/*/audit.md"]
    },
    "network": {
        "allowed": []
    },
    "jira": { "read": true, "write": true },
    "git": { "read": false, "write": false },
    "required_outputs": [
        { "file": "triage.json", "schema": "triage" }
    ],
    "credentials": [],
    "exec": {
        "allow_patterns": [
            "acli jira *",
            "python3 *",
            "cat *",
            "mkdir *",
            "./scripts/report-to-dashboard.sh *"
        ]
    }
}
