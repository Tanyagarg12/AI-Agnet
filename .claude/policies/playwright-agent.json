{
    "agent": "playwright-agent",
    "model": "sonnet",
    "max_turns": 40,
    "filesystem": {
        "read": ["memory/tickets/*"],
        "write": ["memory/tickets/*/playwright-data.json", "memory/tickets/*/checkpoint.json", "memory/tickets/*/audit.md"]
    },
    "network": {
        "allowed": ["stg.app.ox.security", "dev.app.ox.security"]
    },
    "jira": { "read": false, "write": false },
    "git": { "read": false, "write": false },
    "required_outputs": [
        { "file": "playwright-data.json", "schema": "playwright" }
    ],
    "credentials": ["$STAGING_URL", "$STAGING_USER", "$STAGING_PASSWORD"],
    "exec": {
        "allow_patterns": [
            "playwright-cli *",
            "node .claude/skills/chrome-cdp/scripts/cdp.mjs *",
            "python3 *",
            "cat *",
            "mkdir *",
            "./scripts/report-to-dashboard.sh *"
        ]
    }
}
